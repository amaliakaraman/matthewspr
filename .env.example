# ─────────────────────────────────────────────────────────────
#  SUPABASE
#  Create a project at https://supabase.com → Settings → API
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Token encryption (generate with `openssl rand -base64 32`)
TOKEN_ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────
#  ANTHROPIC (Claude AI for insights + recap copy)
#  https://console.anthropic.com/settings/keys
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────────────────────
#  CRON (Vercel scheduled functions)
#  Generate any random string — used to authenticate cron calls.
# ─────────────────────────────────────────────────────────────
CRON_SECRET=

# ─────────────────────────────────────────────────────────────
#  ALERTS (optional)
#  Slack-incoming-webhook-compatible URL. Posts when any platform
#  connection flips out of `connected` (token revoked, refresh failed,
#  etc.) or recovers. Works with Slack, Discord (append `/slack`), or
#  any Zapier/Make webhook. Leave blank to disable.
# ─────────────────────────────────────────────────────────────
ALERT_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────
#  VERCEL BLOB (for post screenshot storage)
#  https://vercel.com → Storage → Blob → New Store
# ─────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ─────────────────────────────────────────────────────────────
#  PLATFORM CREDENTIALS
#  See OAUTH_SETUP.md for step-by-step app creation per platform.
# ─────────────────────────────────────────────────────────────

# Spotify for Podcasters / Spotify API
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# YouTube Data API v3 (Google Cloud Console → APIs → YouTube Data API)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Instagram Graph API (via Meta for Developers)
# Requires a Facebook Page connected to an IG Business/Creator account.
# INSTAGRAM_CLIENT_ID is the Facebook App ID; INSTAGRAM_CLIENT_SECRET is the
# Facebook App Secret. The Instagram OAuth flow goes through Facebook.
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# TikTok Display / Login Kit
# https://developers.tiktok.com/apps
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# LinkedIn Marketing Developer Platform
# https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# X (Twitter) API v2 — OAuth 2.0 with PKCE
# https://developer.x.com/en/portal/dashboard
X_CLIENT_ID=
X_CLIENT_SECRET=

# Captivate.fm (podcast hosting)
# Generate API key at: https://captivate.fm → Account → Integrations
CAPTIVATE_USER_ID=
CAPTIVATE_API_KEY=
